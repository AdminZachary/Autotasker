SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-chars

# If these MySQL variables are set, the app will prefer MySQL.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=autotasker

# Optional fallback if you want to override the default SQLite path directly.
# DATABASE_URL=sqlite:///data/autotasker.db

# Optional server-side AI keys. If omitted, you can still fill API keys in the UI.
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
